#!/usr/bin/env bash
# One-time setup: symlink into Claude Code skills directory and build
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_DIR="$HOME/.claude/skills/cosmo-panel"

# Symlink into Claude Code skills
if [ -L "$SKILL_DIR" ]; then
  echo "Symlink already exists: $SKILL_DIR → $(readlink "$SKILL_DIR")"
elif [ -d "$SKILL_DIR" ]; then
  echo "Warning: $SKILL_DIR already exists as a directory. Skipping symlink."
  echo "Remove it manually if you want to use this repo: rm -rf $SKILL_DIR"
else
  mkdir -p "$HOME/.claude/skills"
  ln -sf "$SCRIPT_DIR" "$SKILL_DIR"
  echo "Linked: $SKILL_DIR → $SCRIPT_DIR"
fi

# Build SKILL.md files from templates
if command -v bun &>/dev/null; then
  cd "$SCRIPT_DIR" && bun run build
  echo "Built SKILL.md files."
else
  echo "Warning: bun not found. Install it (curl -fsSL https://bun.sh/install | bash) then run: bun run build"
fi

echo ""
echo "Done! Available commands in Claude Code:"
echo "  /review-paper    /review-code     /bias-test"
echo "  /write-paper     /check-physics   /compare-codes"
echo "  /brainstorm      /respond-referee /prep-talk"
